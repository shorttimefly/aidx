PORT=8787

# Required in production. When omitted, /api/generate returns mock images so
# the account, quota, asset, and history flow can be tested locally.
IMAGE_API_KEY=
IMAGE_API_ENDPOINT=https://aokapi.com/v1beta/models/gemini-2.5-flash-image:generateContent/
IMAGE_API_MODEL=gemini-2.5-flash-image

# Persistent data. In production, mount this directory to a durable disk.
IMAGE_STUDIO_STORAGE=./storage
IMAGE_STUDIO_DB=./storage/image_studio.sqlite

FREE_QUOTA_CREDITS=20
CREDITS_PER_IMAGE=1
SESSION_DAYS=14

# For local file:// frontend testing. Use your real domain in production.
CORS_ORIGIN=*

# Mock billing grants credits immediately. Set to 0 when wiring a real payment
# provider webhook.
MOCK_BILLING_AUTOGRANT=1

# Keep disabled in production unless you intentionally allow client-provided
# model endpoints/API keys.
ALLOW_CLIENT_IMAGE_CONFIG=0
