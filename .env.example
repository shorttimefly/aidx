PORT=8787
HOST=127.0.0.1

# Persistent data. In production, mount this directory to a durable disk.
IMAGE_STUDIO_STORAGE=./storage
IMAGE_STUDIO_DB=./storage/image_studio.sqlite

SESSION_DAYS=14

# Required in production. The defaults are only for local testing.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Redemption code security pepper (required for redeem code feature).
# Generate a random 32-character string: python3 -c "import secrets; print(secrets.token_hex(16))"
REDEEM_PEPPER=change-me-in-production

# Initial credits for new users (default: 10)
DEFAULT_CREDITS=10
